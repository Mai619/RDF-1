<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:prop="http://nfu.edu.csie.ccsd/11463155/#"
         xml:base="http://nfu.edu.tw/11463155/#">

  <owl:Ontology rdf:about="http://nfu.edu.tw/11463155/traffic-ontology"/>

  <owl:Class rdf:about="#SmartTrafficEntity"/>
  
  <owl:Class rdf:about="#TrafficDevice"><rdfs:subClassOf rdf:resource="#SmartTrafficEntity"/></owl:Class>
  <owl:Class rdf:about="#VisualSensor"><rdfs:subClassOf rdf:resource="#TrafficDevice"/></owl:Class>
  <owl:Class rdf:about="#ANPRCamera"><rdfs:subClassOf rdf:resource="#VisualSensor"/></owl:Class>
  <owl:Class rdf:about="#CCTVCamera"><rdfs:subClassOf rdf:resource="#VisualSensor"/></owl:Class>

  <owl:Class rdf:about="#TrafficElement"><rdfs:subClassOf rdf:resource="#SmartTrafficEntity"/></owl:Class>
  <owl:Class rdf:about="#Vehicle"><rdfs:subClassOf rdf:resource="#TrafficElement"/></owl:Class>
  <owl:Class rdf:about="#Car"><rdfs:subClassOf rdf:resource="#Vehicle"/></owl:Class>
  <owl:Class rdf:about="#Truck"><rdfs:subClassOf rdf:resource="#Vehicle"/></owl:Class>
  <owl:Class rdf:about="#LicensePlate"><rdfs:subClassOf rdf:resource="#TrafficElement"/></owl:Class>

  <owl:Class rdf:about="#TrafficEnvironment"><rdfs:subClassOf rdf:resource="#SmartTrafficEntity"/></owl:Class>
  <owl:Class rdf:about="#Location"><rdfs:subClassOf rdf:resource="#TrafficEnvironment"/></owl:Class>
  <owl:Class rdf:about="#Intersection"><rdfs:subClassOf rdf:resource="#Location"/></owl:Class>
  <owl:Class rdf:about="#RoadSegment"><rdfs:subClassOf rdf:resource="#Location"/></owl:Class>
  <owl:Class rdf:about="#ImageFrame"><rdfs:subClassOf rdf:resource="#TrafficEnvironment"/></owl:Class>

  <owl:ObjectProperty rdf:about="http://nfu.edu.csie.ccsd/11463155/#isNextTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:domain rdf:resource="#Vehicle"/>
    <rdfs:range rdf:resource="#Vehicle"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://nfu.edu.csie.ccsd/11463155/#sameLocationAs">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:domain rdf:resource="#Location"/>
    <rdfs:range rdf:resource="#Location"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://nfu.edu.csie.ccsd/11463155/#hasPlate">
    <rdfs:domain rdf:resource="#Vehicle"/>
    <rdfs:range rdf:resource="#LicensePlate"/>
    <owl:inverseOf rdf:resource="http://nfu.edu.csie.ccsd/11463155/#isPlateOf"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://nfu.edu.csie.ccsd/11463155/#isPlateOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="#LicensePlate"/>
    <rdfs:range rdf:resource="#Vehicle"/>
    <owl:inverseOf rdf:resource="http://nfu.edu.csie.ccsd/11463155/#hasPlate"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="http://nfu.edu.csie.ccsd/11463155/#hasVIN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="#Vehicle"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="http://nfu.edu.csie.ccsd/11463155/#capturedFrame">
    <rdfs:domain rdf:resource="#TrafficDevice"/>
    <rdfs:range rdf:resource="#ImageFrame"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://nfu.edu.csie.ccsd/11463155/#containsVehicle">
    <rdfs:domain rdf:resource="#ImageFrame"/>
    <rdfs:range rdf:resource="#Vehicle"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://nfu.edu.csie.ccsd/11463155/#locatedIn">
    <rdfs:domain rdf:resource="#TrafficDevice"/>
    <rdfs:range rdf:resource="#Location"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="http://nfu.edu.csie.ccsd/11463155/#hasTimestamp">
    <rdfs:domain rdf:resource="#ImageFrame"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>

</rdf:RDF>